{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2018"]
	},
	"include": [
		"main.ts",
		"types/**/*.d.ts",
		"src/**/*.ts",
		"React/**/*.ts",
		"React/**/*.tsx",
		"Views/**/*.ts",
		"Views/**/*.tsx"
	]
}
